{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "installCommand": "bun install",
  "devCommand": "next dev",
  "regions": ["fra1"],
  "git": {
    "deploymentEnabled": true
  }
}
