{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "check": "npm run lint && npm run build",
    "supabase:create-admin": "node scripts/create-supabase-admin.mjs",
    "workers:ai:types": "wrangler types --config workers/ai/wrangler.jsonc workers/ai/worker-configuration.d.ts",
    "workers:ai:check": "wrangler deploy --dry-run --config workers/ai/wrangler.jsonc",
    "workers:ai:dev": "wrangler dev --config workers/ai/wrangler.jsonc",
    "workers:ai:deploy": "wrangler deploy --config workers/ai/wrangler.jsonc",
    "workers:ai:secret": "wrangler secret put AI_ROUTER_SHARED_SECRET --config workers/ai/wrangler.jsonc"
  },
