{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "braided-digital-ai",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-28",
  "workers_dev": true,
  "upload_source_maps": true,
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "vars": {
    "ENVIRONMENT": "production",
    "DEFAULT_MODEL": "@cf/qwen/qwen3-30b-a3b-fp8",
    "ALLOWED_MODELS": "@cf/qwen/qwen3-30b-a3b-fp8,@cf/meta/llama-3.2-3b-instruct,@cf/zai-org/glm-4.7-flash,@cf/google/gemma-4-26b-a4b-it,@cf/meta/llama-4-scout-17b-16e-instruct,@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  }
}
