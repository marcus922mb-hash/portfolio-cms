// Prisma schema for Portfolio CMS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  summary     String
  description String   // Markdown content
  techStack   String   // JSON array as string (SQLite limitation)
  demoUrl     String?
  repoUrl     String?
  imageUrl    String?
  status      String   @default("published") // "draft" | "published"
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([order])
}
